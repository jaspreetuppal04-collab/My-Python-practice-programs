class Person:
    def show(self):
        print("This method will be implemented in the child class")


class Student(Person):
    def __init__(self):
        self.__name = ""

    def set_name(self, name):
        self.__name = name

    def get_name(self):
        return self.__name

    def show(self):
        print("Name:", self.__name)


s = Student()
s.set_name("Rahul")
print(s.get_name())
s.show()
